generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TipoDocumento {
  id             String        @id @default(uuid())
  descripcion    String
  cuentaContable String
  estado         String        @default("ACTIVO") // "ACTIVO" o "INACTIVO"
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  transacciones  Transaccion[]
}

model Cliente {
  id               String        @id @default(uuid())
  nombre           String
  cedula           String        @unique
  limiteCredito    Float
  estado           String        @default("ACTIVO") // "ACTIVO" o "INACTIVO"
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  transacciones    Transaccion[]
  asientos         AsientoContable[]
}

model Transaccion {
  id               String        @id @default(uuid())
  tipoMovimiento   String        // "DB" (Débito) o "CR" (Crédito)
  numeroDocumento  String
  fecha            DateTime
  monto            Float
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relaciones
  tipoDocumentoId  String
  tipoDocumento    TipoDocumento @relation(fields: [tipoDocumentoId], references: [id], onDelete: Restrict)
  
  clienteId        String
  cliente          Cliente       @relation(fields: [clienteId], references: [id], onDelete: Restrict)
}

model AsientoContable {
  id               String        @id @default(uuid())
  descripcion      String
  cuenta           String
  tipoMovimiento   String        // "DB" o "CR"
  fechaAsiento     DateTime
  montoAsiento     Float
  estado           String        @default("REGISTRADO") // ej: "PENDIENTE", "REGISTRADO", "ERROR"
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relaciones
  clienteId        String
  cliente          Cliente       @relation(fields: [clienteId], references: [id], onDelete: Restrict)
}
